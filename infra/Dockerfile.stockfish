FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    stockfish \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir fastapi uvicorn[standard] chess

COPY stockfish_api.py /app/stockfish_api.py

WORKDIR /app
EXPOSE 8001
CMD ["uvicorn", "stockfish_api:app", "--host", "0.0.0.0", "--port", "8001"]
